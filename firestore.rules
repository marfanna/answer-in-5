rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow reading and writing for battles collection
    match /battles/{battleId} {
      allow read, write: if true;
    }
    
    // Allow reading and writing for scores collection
    match /scores/{scoreId} {
      allow read, write: if true;
    }
    
    // Allow reading and writing for niche statistics
    match /niche_stats/{nicheId} {
      allow read, write: if true;
    }
  }
}
